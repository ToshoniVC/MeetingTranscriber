// Release.xcconfig
//
// The production build. Installed in /Applications, auto-updates via Sparkle
// (wired in Phase 8 per Claude/implementation-plan.md). See
// Claude/development-lifecycle.md §2 for the dual-install model.

PRODUCT_NAME = Jot
PRODUCT_BUNDLE_IDENTIFIER = com.toshonivc.jot
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon

// Versioning per Claude/development-lifecycle.md §5.2
MARKETING_VERSION = 0.4.5
CURRENT_PROJECT_VERSION = 1

// Code signing — ad-hoc (no Apple Developer ID needed). First install of the
// .app from a GitHub Release will trigger a one-time Gatekeeper "Open Anyway"
// dialog; Sparkle-driven updates after that do not re-trigger Gatekeeper.
CODE_SIGN_IDENTITY = -
CODE_SIGN_STYLE = Manual
DEVELOPMENT_TEAM =
