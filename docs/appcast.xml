<?xml version="1.0" encoding="utf-8"?>
<!--
    Sparkle appcast for Jot. Regenerated automatically by
    .github/workflows/release.yml on every `v*` tag. Hosted on GitHub Pages
    from this `docs/` folder so the URL stays stable across releases:

        https://toshonivc.github.io/MeetingTranscriber/appcast.xml

    Empty `<item>` list until the first tagged release. Sparkle treats a
    feed with no items as "no updates available" — which is the right
    answer pre-launch.

    To bootstrap GitHub Pages: repo Settings → Pages → Source = "Deploy
    from a branch" → Branch = `main`, Folder = `/docs` → Save.
-->
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     version="2.0">
    <channel>
        <title>Jot</title>
        <link>https://toshonivc.github.io/MeetingTranscriber/appcast.xml</link>
        <description>Updates for Jot — the macOS meeting transcription menu-bar utility.</description>
        <language>en</language>
    </channel>
</rss>
